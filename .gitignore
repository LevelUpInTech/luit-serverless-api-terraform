# Local .terraform directories
**/.terraform/*

# .tfstate files (we use remote state — never commit these)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Lambda build artifacts
build/
*.zip

# Python
__pycache__/
*.pyc
.venv/
venv/

# IDE / OS
.idea/
.vscode/
.DS_Store
